# MediaForge v2 Configuration
# Copy this file to .env and update values

# =============================================================================
# REQUIRED
# =============================================================================

# Secret key for JWT signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-string

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=sqlite+aiosqlite:///config/db/mediaforge.db

# =============================================================================
# JELLYFIN (External — your existing Jellyfin server)
# =============================================================================

JELLYFIN_URL=http://192.168.2.54:8096
JELLYFIN_API_KEY=

# =============================================================================
# VPN (Gluetun Configuration)
# =============================================================================

VPN_PROVIDER=protonvpn
VPN_TYPE=wireguard
VPN_PRIVATE_KEY=
VPN_ADDRESSES=
VPN_COUNTRIES=Canada

# =============================================================================
# PATHS
# =============================================================================

CONFIG_DIR=/config
DOWNLOAD_DIR=/downloads
MEDIA_DIR=/media

# =============================================================================
# CONTAINER
# =============================================================================

TZ=America/Toronto
PUID=1000
PGID=1000

# =============================================================================
# APPLICATION
# =============================================================================

LOG_LEVEL=INFO
APP_PORT=8686

# =============================================================================
# TMDB
# =============================================================================

TMDB_API_KEY=
