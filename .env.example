# MediaForge Configuration
# Copy this file to .env and update values

# =============================================================================
# REQUIRED
# =============================================================================

# Secret key for JWT signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-string

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL (recommended):
# DATABASE_URL=postgresql+asyncpg://mediaforge:password@localhost:5432/mediaforge
# SQLite (default, simpler setup):
DATABASE_URL=sqlite+aiosqlite:///config/db/mediaforge.db

# =============================================================================
# REDIS
# =============================================================================

REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JELLYFIN
# =============================================================================

JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=

# =============================================================================
# VPN
# =============================================================================

VPN_PROVIDER=
VPN_TYPE=wireguard
VPN_CONFIG_PATH=/config/vpn/wg0.conf

# =============================================================================
# PATHS
# =============================================================================

CONFIG_DIR=/config
DOWNLOAD_DIR=/downloads
MEDIA_DIR=/media

# =============================================================================
# CONTAINER
# =============================================================================

TZ=America/Toronto
PUID=1000
PGID=1000

# =============================================================================
# APPLICATION
# =============================================================================

LOG_LEVEL=INFO
APP_PORT=8686
